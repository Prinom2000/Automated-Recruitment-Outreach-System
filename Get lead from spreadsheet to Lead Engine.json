      "parameters": {
        "jsCode": "return [\n  {\n    json: {\n      phone: (() => {\n        let phone = String($input.first().json.Phone).replace(/\\D/g, '');\n\n        // If starts with 8, replace first digit with 7\n        if (phone.startsWith('8')) {\n          phone = '7' + phone.slice(1);\n        }\n\n        return phone;\n      })()\n    }\n  }\n];"
      },
