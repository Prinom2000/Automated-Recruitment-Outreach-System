    {
      "parameters": {
        "jsCode": "// ========================================\n// ১৮০ বার লুপের LIMIT কন্ট্রোল\n// ========================================\nconst MAX_LOOP_LIMIT = 1;\n\n// সব ইনপুট আইটেম নাও\nconst allItems = $input.all();\n\n// মোট আইটেম সংখ্যা\nconst totalItems = allItems.length;\n\n// ম্যাক্সিমাম ১৮০ পর্যন্ত সীমাবদ্ধ করো\nconst itemsToProcess = allItems.slice(0, MAX_LOOP_LIMIT);\n\nconsole.log(`মোট ডাটা: ${totalItems} টি`);\nconsole.log(`প্রসেস করা হবে: ${itemsToProcess.length} টি (সর্বোচ্চ ${MAX_LOOP_LIMIT})`);\n\n// প্রতিটি আইটেমে loop_index এবং limit info যোগ করো\nconst processedItems = itemsToProcess.map((item, index) => {\n  return {\n    json: {\n      ...item.json,\n      loop_index: index + 1,\n      loop_limit: MAX_LOOP_LIMIT,\n      total_available: totalItems,\n      is_last_item: index === itemsToProcess.length - 1\n    }\n  };\n});\n\nreturn processedItems;"
      },
