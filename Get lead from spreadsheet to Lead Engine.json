      "parameters": {
        "jsCode": "const allRows = $input.all();\n\nlet maxId = 0;\nfor (const row of allRows) {\n  const id = parseInt(row.json['Lead ID']);\n  if (!isNaN(id) && id > maxId) {\n    maxId = id;\n  }\n}\n\nreturn [{\n  json: {\n    maxLeadId: maxId\n  }\n}];"
